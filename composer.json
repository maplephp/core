  "require": {
    "php": ">=8.2",
    "psr/http-server-middleware": "^1.0",
    "maplephp/http": "^2.0",
    "maplephp/container": "^2.0",
    "maplephp/blunder": "*",
    "maplephp/dto": "^3.1",
    "maplephp/emitron": "*",
    "maplephp/validate": "^2.0",
    "maplephp/prompts": "^1.2",
    "maplephp/cache": "^2.0",
    "maplephp/log": "^v2.0"
